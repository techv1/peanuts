<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        app:title="Simulation Engine Settings"
        app:iconSpaceReserved="false">

        <EditTextPreference
            app:key="update_interval_ms"
            app:title="Update Interval (ms)"
            app:summary="Default: 1000ms"
            app:defaultValue="1000"
            android:inputType="number"
            app:iconSpaceReserved="false" />

        <ListPreference
            app:key="stop_mode"
            app:title="Stop Behavior"
            app:summary="Choose how the simulation stops"
            app:entries="@array/stop_mode_entries"
            app:entryValues="@array/stop_mode_values"
            app:defaultValue="GRADUAL"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            app:key="altitude_enabled"
            app:title="Simulate Altitude"
            app:summary="Auto-fetch altitude and apply sine wave drift"
            app:defaultValue="true"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        app:title="Location Search &amp; Input"
        app:iconSpaceReserved="false">

        <SwitchPreferenceCompat
            app:key="nominatim_enabled"
            app:title="OpenStreetMap Search"
            app:summary="Enable location search via Nominatim"
            app:defaultValue="true"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        app:title="About Peanuts"
        app:iconSpaceReserved="false">

        <Preference
            app:key="app_version"
            app:title="Version"
            app:summary="1.0 (Build 1)"
            app:iconSpaceReserved="false" />

        <Preference
            app:key="package_name"
            app:title="Package"
            app:summary="com.studiodragon.peanuts"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

</PreferenceScreen>
